# Datasets - DON'T PUSH
all_class_partition/
global_val/
testing/
training/

# Virtual environments - DON'T PUSH
vyolo/
venv/
env/

# Other code directories (push separately)
fl_yolo/
fl_app/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Outputs and results - DON'T PUSH
**/output/
**/outputs/
**/temp/
**/temp_eval/
**/inferences*/
**/logs/
**/runs/
**/preds*/
**/client_datasets/
**/fl_dataset/images/
**/fl_dataset/partitions/
**/datasets/

# Allow centralized results
!centralized/final_outputs/
!centralized/kitti_analysis/

# Model weights
*.pth
*.pt

# Dataset annotations
**/annotations/*.json

# Large result files (over 50MB)
**/metrics1.json
**/coco_instances_results.json

# IDE
.vscode/
.idea/

# Temporary files
*.log
.DS_Store

# Root scripts
*.py
*.txt
*.sh
!centralized/**/*.py
!centralized/**/*.txt
!centralized/**/*.sh
!README.md
!requirements.txt

# FL YOLO specific exclusions
fl_yolo/client_datasets/
fl_yolo/datasets_iid/
fl_yolo/datasets/
fl_yolo/temp/
